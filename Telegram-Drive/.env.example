## Telegram-Drive deployment environment variables
# Networking
STREAM_PORT=14201
STREAM_TOKEN=replace_with_a_secure_hex_token
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Application data and backups
APP_DATA_DIR=/data/telegram-drive
BACKUPS_DIR=/backups

# Optional S3 backup (set only if you use S3)
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GitHub push automation (optional)
GITHUB_REPO=owner/repo
GITHUB_PUSH_TOKEN=
